<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/widget_bg">

    <!-- Top row: Location + Condition -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_eyebrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STRATA · NOW"
                android:textSize="8sp"
                android:textColor="#8a8070"
                android:letterSpacing="0.15"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/widget_location"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:textSize="13sp"
                android:textColor="#0f0e0c"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_condition"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textSize="13sp"
            android:textColor="#c4411c"
            android:textStyle="italic" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        android:background="#1A0f0e0c" />

    <!-- Giant Temperature -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="bottom">

        <TextView
            android:id="@+id/widget_temp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textSize="52sp"
            android:textColor="#0f0e0c"
            android:textStyle="bold"
            android:includeFontPadding="false" />

        <TextView
            android:id="@+id/widget_temp_unit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="°C"
            android:textSize="16sp"
            android:textColor="#8a8070"
            android:fontFamily="monospace"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="end"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/widget_feels"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Feels --°"
                android:textSize="9sp"
                android:textColor="#8a8070"
                android:fontFamily="monospace" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="3dp">

                <TextView
                    android:id="@+id/widget_hi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↑ --°"
                    android:textSize="10sp"
                    android:textColor="#c4411c"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/widget_lo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  ↓ --°"
                    android:textSize="10sp"
                    android:textColor="#1c5dc4"
                    android:fontFamily="monospace" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="#1A0f0e0c" />

    <!-- Stats row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Humidity -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/widget_humidity_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--%"
                android:textSize="12sp"
                android:textColor="#0f0e0c"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Humidity"
                android:textSize="7sp"
                android:textColor="#8a8070"
                android:fontFamily="monospace"
                android:letterSpacing="0.1" />
        </LinearLayout>

        <!-- Wind -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/widget_wind_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- mph"
                android:textSize="12sp"
                android:textColor="#0f0e0c"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Wind"
                android:textSize="7sp"
                android:textColor="#8a8070"
                android:fontFamily="monospace"
                android:letterSpacing="0.1" />
        </LinearLayout>

        <!-- UV -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/widget_uv_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UV --"
                android:textSize="12sp"
                android:textColor="#0f0e0c"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Index"
                android:textSize="7sp"
                android:textColor="#8a8070"
                android:fontFamily="monospace"
                android:letterSpacing="0.1" />
        </LinearLayout>

        <!-- Rain -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/widget_precip_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--%"
                android:textSize="12sp"
                android:textColor="#0f0e0c"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rain"
                android:textSize="7sp"
                android:textColor="#8a8070"
                android:fontFamily="monospace"
                android:letterSpacing="0.1" />
        </LinearLayout>
    </LinearLayout>

    <!-- Updated timestamp -->
    <TextView
        android:id="@+id/widget_updated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Updated --:--"
        android:textSize="7sp"
        android:textColor="#8a8070"
        android:fontFamily="monospace"
        android:gravity="end"
        android:layout_marginTop="8dp"
        android:letterSpacing="0.1" />

</LinearLayout>
